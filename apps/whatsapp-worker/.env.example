PORT=3000
SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=cole_a_service_role_key_aqui
CORS_ORIGIN=http://localhost:5173
# Diretório persistente. Monte-o como volume no provedor de deploy.
WHATSAPP_AUTH_PATH=.wwebjs_auth
# Opcional: permite executar Chromium em container sem sandbox.
PUPPETEER_ARGS=--no-sandbox,--disable-setuid-sandbox
